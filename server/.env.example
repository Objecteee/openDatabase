# 302.ai API
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.302.ai

# Mistral OCR（PDF 解析，通过 302.ai 转发）
# 使用 AI_API_KEY 即可，无需单独配置
# 如需指定模型版本，可设置（默认 mistral-ocr-latest）
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# DeepSeek（智能切片 + 语义增强，txt/md/pdf 专用）
# 文档：https://platform.deepseek.com/api-docs/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Supabase（Project Settings → API）
# 项目 ref 从 db.xxx.supabase.co 的 xxx 部分获取
# API URL 格式：https://<project-ref>.supabase.co
SUPABASE_URL=https://lrehdsqwbbsvlkheuyeo.supabase.co
# 服务端密钥（二选一）：
# - 新版：sb_secret_xxx（Secret keys 区域）
# - 旧版：eyJ...（Legacy API Keys → service_role）
SUPABASE_SERVICE_KEY=your_service_role_or_secret_key_here

# 直连 PostgreSQL（可选，用于 psql/迁移等）
# postgresql://postgres:<数据库密码>@db.lrehdsqwbbsvlkheuyeo.supabase.co:5432/postgres

# 服务端口
PORT=3000

# refresh_token Cookie 的 Secure 属性：
# - 线上 HTTPS 建议 true
# - 仅 HTTP（公网 IP:端口）部署时设为 false，否则浏览器不会回传 refresh cookie
# - 未设置时：生产环境默认 true，开发环境默认 false
# COOKIE_SECURE=false
