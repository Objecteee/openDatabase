    "test:video": "node video-understanding.test.js",
    "test:whisperx": "node whisperx.test.js",
    "test:pdf": "node pdf-mineru.test.js",
    "test:doc-parse": "node doc-parse.test.js",
    "test:doc-parse:complex": "node scripts/generate-sample-pdf.js && node doc-parse.test.js samples/complex-sample.pdf",
